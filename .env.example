# Get a free key at https://halalterminal.com
HALAL_TERMINAL_API_KEY=ht_...

# Optional: limit symbols screened during dev (default: all from pine/symbols.txt)
# HALAL_PINE_LIMIT=20

# Optional: parallel screen requests (default: 4)
# HALAL_PINE_CONCURRENCY=4

# Optional override of the API base URL
# HALAL_API_BASE=https://api.halalterminal.com
